# Azure AI Foundry
PROJECT_ENDPOINT=https://your-project.services.ai.azure.com
MODEL_DEPLOYMENT_NAME=gpt-4o

# LangSmith OTLP ingestion
LANGSMITH_OTEL_ENDPOINT=https://api.smith.langchain.com/otel/v1/traces
LANGSMITH_API_KEY=lsv2_your_api_key_here

# OpenTelemetry
OTEL_SERVICE_NAME=foundry-otel-langsmith
DEPLOYMENT_ENVIRONMENT=development

# Optional: set to "true" to include message content in traces (prompts, responses)
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
